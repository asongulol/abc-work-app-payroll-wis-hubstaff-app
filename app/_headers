# Response headers for the served app/ files (honored by Cloudflare Pages and
# Workers static assets). Keep the app out of search indexes + basic hardening.
# NOTE: no Content-Security-Policy here on purpose — the app loads React, Babel,
# Tailwind and supabase-js from CDNs at runtime, so a strict CSP would break it.
/*
  X-Robots-Tag: noindex, nofollow
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  # The whole app is ONE HTML file (everything else loads from CDNs at runtime),
  # so there is nothing worth caching locally. Always revalidate the shell with
  # the server (cheap 304 via ETag) so a new deploy shows up immediately without
  # needing a hard refresh.
  Cache-Control: no-cache
