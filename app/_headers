# Response headers for the served app/ files (honored by Cloudflare Pages and
# Workers static assets). Keep the app out of search indexes + basic hardening.
#
# Content-Security-Policy is shipped in REPORT-ONLY mode (M2). The app compiles
# itself in-browser with Babel-standalone (needs 'unsafe-eval') and renders an
# inline <script type="text/babel"> block plus the kill-switch + module import
# (needs 'unsafe-inline'), so the realistic protection here is host-allowlisting
# external scripts/connections — NOT inline-script blocking. Report-only never
# blocks anything; it just posts console violations so we can confirm the
# allowlist is complete before flipping to an enforcing `Content-Security-Policy`.
# Hosts: cdnjs (React/ReactDOM/Babel), esm.sh (supabase-js), *.supabase.co
# (REST/realtime/storage/functions), app.hubstaff.com + open.er-api.com (FX) for
# fetches, accounts.google.com for the OAuth redirect.
/*
  X-Robots-Tag: noindex, nofollow
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Content-Security-Policy-Report-Only: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://esm.sh; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; img-src 'self' data: https:; font-src 'self' data: https://cdnjs.cloudflare.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://app.hubstaff.com https://open.er-api.com https://esm.sh; form-action 'self' https://accounts.google.com; frame-src 'self' https://accounts.google.com
  # Images/favicon: revalidate (cheap 304s).
  Cache-Control: no-cache

# The app shell is ONE HTML file (everything else loads from CDNs at runtime).
# Use no-store so the browser NEVER reuses a stored copy — a new deploy always
# shows up on a normal refresh, no hard-refresh needed. (no-cache still let some
# browsers serve a stale shell via a 304; no-store removes that path entirely.)
/
  Cache-Control: no-store, must-revalidate
/index.html
  Cache-Control: no-store, must-revalidate
/legacy.html
  Cache-Control: no-store, must-revalidate
