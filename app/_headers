# Response headers for the served app/ files (honored by Cloudflare Pages and
# Workers static assets). Keep the app out of search indexes + basic hardening.
# NOTE: no Content-Security-Policy here on purpose — the app loads React, Babel,
# Tailwind and supabase-js from CDNs at runtime, so a strict CSP would break it.
/*
  X-Robots-Tag: noindex, nofollow
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  # Images/favicon: revalidate (cheap 304s).
  Cache-Control: no-cache

# The app shell is ONE HTML file (everything else loads from CDNs at runtime).
# Use no-store so the browser NEVER reuses a stored copy — a new deploy always
# shows up on a normal refresh, no hard-refresh needed. (no-cache still let some
# browsers serve a stale shell via a 304; no-store removes that path entirely.)
/
  Cache-Control: no-store, must-revalidate
/index.html
  Cache-Control: no-store, must-revalidate
/legacy.html
  Cache-Control: no-store, must-revalidate
