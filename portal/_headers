# Response headers for the contractor portal (Cloudflare Workers static assets).
# The portal is ONE HTML file (everything else loads from CDNs at runtime), so
# always revalidate the shell with the server (cheap 304 via ETag) — a new
# deploy then shows up immediately, no hard refresh needed.
# Content-Security-Policy ships in REPORT-ONLY mode (M2) — same rationale as the
# admin app: in-browser Babel needs 'unsafe-eval', inline blocks need
# 'unsafe-inline', so the value is host-allowlisting, not inline blocking. The
# portal additionally loads Cloudflare Turnstile (challenges.cloudflare.com) for
# the login/reset CAPTCHA — its script-src + the iframe it renders (frame-src) are
# allowlisted. Report-only never blocks; it surfaces console violations so we can
# confirm the allowlist before flipping to an enforcing `Content-Security-Policy`.
/*
  Cache-Control: no-cache
  X-Robots-Tag: noindex, nofollow
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Content-Security-Policy-Report-Only: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://esm.sh https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; img-src 'self' data: https:; font-src 'self' data: https://cdnjs.cloudflare.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.open-meteo.com https://esm.sh https://challenges.cloudflare.com; form-action 'self'; frame-src 'self' https://challenges.cloudflare.com

# The portal shell is ONE HTML file — no-store so the browser never reuses a
# stale copy; a new deploy always shows on a normal refresh.
/
  Cache-Control: no-store, must-revalidate
/index.html
  Cache-Control: no-store, must-revalidate
